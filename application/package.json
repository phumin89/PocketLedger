{
    "name": "@pocketledger/application",
    "private": true,
    "version": "0.1.0",
    "type": "module",
    "main": "./dist/index.js",
    "types": "./dist/index.d.ts",
    "exports": {
        ".": {
            "types": "./dist/index.d.ts",
            "import": "./dist/index.js"
        }
    },
    "scripts": {
        "prebuild": "npm --prefix .. run build --workspace @pocketledger/contracts && npm --prefix .. run build --workspace @pocketledger/database",
        "build": "tsc -p tsconfig.json"
    },
    "dependencies": {
        "@pocketledger/contracts": "file:../contracts",
        "@pocketledger/database": "file:../database"
    },
    "devDependencies": {
        "@types/node": "^22.14.1",
        "typescript": "^5.8.3"
    }
}
